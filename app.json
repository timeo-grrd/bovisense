{
  "expo": {
    "name": "BoviSense",
    "slug": "bovisense",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/logo_bovi_sense_clair.png",
    "scheme": "bovisense",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/logo_bovi_sense_clair.png",
      "resizeMode": "contain",
      "backgroundColor": "#F5F0E8"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.bovisense.app",
      "config": {
        "googleMapsApiKey": "AIzaSyDgsaPYXxaefvrDGxNtnBsl_0bL_StlTIY"
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/logo_bovi_sense_clair.png",
        "backgroundColor": "#F5F0E8"
      },
      "package": "com.bovisense.app",
      "versionCode": 1,
      "config": {
        "googleMaps": {
          "apiKey": "AIzaSyDgsaPYXxaefvrDGxNtnBsl_0bL_StlTIY"
        }
      },
      "edgeToEdgeEnabled": true,
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "RECEIVE_BOOT_COMPLETED",
        "VIBRATE",
"android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
[
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "BoviSense utilise votre localisation pour afficher la météo de votre exploitation."
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/logo_bovi_sense_clair.png",
          "color": "#2D5016",
          "defaultChannel": "bovisense"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "be202770-a078-4080-8a04-76c154210def"
      }
    }
  }
}
